# Telegram Bot Token (обязательно - замените на свой)
BOT_TOKEN=ваш_токен_бота_здесь

# Database settings
DB_PATH=bot_data.db

# Bot settings
MAX_WARNS=3
LOG_LEVEL=INFO
DEBUG=False

# Mute durations (in minutes)
MUTE_15M=15
MUTE_1H=60
MUTE_24H=1440
MUTE_7D=10080

# Welcome message template
DEFAULT_WELCOME=Привет, {name}! Добро пожаловать в чат! 🌟

# Admin settings
ALLOW_BOT_ADMINS=True

# Custom commands settings
MAX_CUSTOM_COMMANDS=50
MAX_COMMAND_NAME_LEN=50
MAX_COMMAND_RESPONSE_LEN=1000

# Timezone
TIMEZONE=Europe/Moscow
